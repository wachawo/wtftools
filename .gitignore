# Local relay / IDE / agent state — never committed.
lmrelay.toml
!lmrelay.toml.example

.idea/
.vscode/
.cursor/
.claude/
.codex

# Python build / cache
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
deb_dist/
*.tar.gz
*.deb
setup.py            # auto-generated by stdeb during build
.venv/
venv/
env/

.mypy_cache/
.ruff_cache/
.pytest_cache/
.pyright/
.coverage
htmlcov/
site/

.env
.env.*
!.env.example

# Editor swap files
*.swp

# All Markdown is ignored by default. The three root docs below are
# whitelisted; everything else must live under docs/ to be tracked.
# Internal notes (PROJECT.md, ad-hoc TODOs, …) thus stay local.
*.md
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!CLAUDE.md
!docs/**/*.md
