# Local relay / IDE / agent state — never committed.
lmrelay.toml
!lmrelay.toml.example

.idea/
.vscode/
.cursor/
.claude/
.codex

# Python build / cache
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
deb_dist/
*.tar.gz
*.deb
setup.py            # auto-generated by stdeb during build
.venv/
venv/
env/

.mypy_cache/
.ruff_cache/
.pytest_cache/
.pyright/
.coverage
htmlcov/
site/

.env
.env.*
!.env.example

# Editor swap files
*.swp

# All Markdown is ignored by default — whitelist only the docs that are part of
# the public repo. Internal notes (PROJECT.md, …) stay local.
*.md
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!QUICKSTART.md
!ROADMAP.md
!PLUGIN_GUIDE.md
!docs/**/*.md
